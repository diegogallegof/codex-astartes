# --- ElevenLabs Voice Engine ---
ELEVENLABS_API_KEY=your_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# --- Agent Thresholds ---
CPU_ALERT_PERCENT=85
RAM_ALERT_PERCENT=90
DISK_ALERT_PERCENT=95

# --- Poll Intervals (seconds) ---
PROCESS_POLL_INTERVAL=15
NETWORK_POLL_INTERVAL=10
HEALTH_POLL_INTERVAL=20

# --- Downloads Guardian ---
DOWNLOADS_SCAN_INTERVAL_MINUTES=30
DOWNLOADS_MAX_AGE_DAYS=30
DOWNLOADS_MAX_FILES=100

# --- Watched Paths ---
WATCHED_PATHS=~/.ssh,~/.bashrc,~/.zshrc,~/.env,~/Documents

# --- Suspicious Network Ports ---
SUSPICIOUS_PORTS=4444,6666,31337,1337,9001

# --- Trusted IPs ---
TRUSTED_IPS=127.0.0.1,192.168.1.1
